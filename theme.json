{
	"version": 3,
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{
					"color": "#ffffff",
					"name": "Background",
					"slug": "background"
				},
				{
					"color": "#14171a",
					"name": "Font",
					"slug": "font"
				},
				{
					"color": "#525252",
					"name": "Font 2",
					"slug": "font-2"
				},
				{
					"color": "#ff7a38",
					"name": "Main 1",
					"slug": "main-1"
				},
				{
					"color": "#2080f7",
					"name": "Main 2",
					"slug": "main-2"
				},
				{
					"color": "#e5e7eb",
					"name": "Gray Light",
					"slug": "gray-light"
				}
			]
		},
		"layout": {
			"contentSize": "750px",
			"wideSize": "1320px"
		},
		"spacing": {
			"defaultSpacingSizes": true,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "10"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "20"
				},
				{
					"name": "Small",
					"size": "clamp(15px, 5vw, 30px);",
					"slug": "30"
				},
				{
					"name": "Medium",
					"size": "clamp(40px, 5vw, 40px);",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(25px, 5vw, 50px);",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(30px, 7vw, 60px);",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(35px, 7vw, 70px);",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "clamp(40px, 10vw, 80px);",
					"slug": "80"
				}
			],
			"units": ["%", "px", "em", "rem", "vh", "vw"]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'PingFang SC','Lantinghei SC','Microsoft YaHei','HanHei SC','Helvetica Neue','Open Sans','Hiragino Sans GB','微软雅黑',STHeiti,'WenQuanYi Micro Hei',Arial,SimSun,sans-serif",
					"slug": "primary",
					"name": "Primary"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "0.75rem",
						"min": "0.75rem"
					},
					"size": "0.75rem",
					"slug": "x-small",
					"name": "Extra Small"
				},
				{
					"fluid": {
						"max": "0.9375rem",
						"min": "0.875rem"
					},
					"size": "0.875rem",
					"slug": "small",
					"name": "Small"
				},
				{
					"size": "1.0rem",
					"slug": "medium",
					"name": "Medium"
				},
				{
					"fluid": {
						"max": "1.25rem",
						"min": "1.125rem"
					},
					"size": "1.125rem",
					"slug": "large",
					"name": "Large"
				},
				{
					"fluid": {
						"max": "1.8rem",
						"min": "1.5rem"
					},
					"size": "1.5rem",
					"slug": "x-large",
					"name": "Extra Large"
				},
				{
					"fluid": {
						"max": "2.5rem",
						"min": "1.875rem"
					},
					"size": "1.875rem",
					"slug": "xx-large",
					"name": "Extra Extra Large"
				}
			]
		},
		"blocks": {
			"core/query-no-results": {
				"border": {
					"color": true,
					"radius": true,
					"style": true,
					"width": true
				}
			}
		}
	},
	"styles": {
		"color": {
			"text": "var:preset|color|font",
			"background": "var:preset|color|background"
		},
		"spacing": {
			"padding": {
				"left": "var(--wp--preset--spacing--30)",
				"right": "var(--wp--preset--spacing--30)"
			},
			"blockGap": "var(--wp--preset--spacing--50)"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|primary",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.4"
		},
		"elements": {
			"button": {
				":hover": {
					"color": {
						"text": "var:preset|color|background",
						"background": "var:preset|color|font-2"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				"border": {
					"radius": "6px"
				},
				"color": {
					"background": "var:preset|color|font",
					"text": "var:preset|color|background"
				},
				"spacing": {
					"blockGap": "1.5rem",
					"padding": {
						"bottom": "var:preset|spacing|30",
						"left": "var:preset|spacing|50",
						"right": "var:preset|spacing|50",
						"top": "var:preset|spacing|30"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|primary",
					"fontWeight": "400",
					"lineHeight": "1.6"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large",
					"lineHeight": "1.5"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large",
					"lineHeight": "1.5"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|x-small"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|primary",
					"fontWeight": "600",
					"lineHeight": "1.4"
				},
				"color": {
					"text": "var:preset|color|font"
				},
				"spacing": {
					"margin": {
						"top": "25px",
						"bottom": "25px"
					},
					"blockGap": "var:preset|spacing|50"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|font-2"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|primary",
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|main-2"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":active": {
					"color": {
						"text": "var:preset|color|font"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"typography": {
						"textDecoration": "underline dashed"
					}
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"color": {
					"text": "var:preset|color|font-2"
				}
			},
			"core/image": {
				"border": {
					"radius": "6px"
				},
				"spacing": {
					"margin": {
						"left": "auto",
						"right": "auto"
					}
				},
				"typography": {
					"textAlign": "center"
				}
			},
			"core/navigation": {
				"spacing": {
					"blockGap": "var:preset|spacing|40"
				},
				"typography": {
					"fontSize": "1rem",
					"fontWeight": "500",
					"textTransform": "uppercase",
					"fontStyle": "normal",
					"letterSpacing": "1px"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						},
						":active": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						},
						":focus": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				},
				"css": "& .wp-block-navigation__responsive-container{padding:0;}"
			},
			"core/navigation-link": {
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/navigation-submenu": {
				"css": "& ul li a{padding:var(--wp--preset--spacing--10);color:var(--wp--preset--color--main-2);}"
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "var:preset|color|main-2",
							"style": "solid",
							"width": "1px"
						},
						"color": {
							"text": "var:preset|color|main-2"
						},
						"spacing": {
							"padding": {
								"bottom": "var:preset|spacing|30",
								"left": "var:preset|spacing|50",
								"right": "var:preset|spacing|50",
								"top": "var:preset|spacing|30"
							}
						}
					}
				}
			},
			"core/site-title": {
				"typography": {
					"textTransform": "uppercase",
					"fontStyle": "normal",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"fontSize": "1.2rem"
				},
				"spacing": { "margin": { "bottom": "0px" } },
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none !important"
						},
						"color": { "text": "var:preset|color|font-2" },
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							},
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/site-tagline": {
				"typography": {
					"textTransform": "uppercase",
					"letterSpacing": "1px"
				},
				"color": { "text": "var:preset|color|font-2" }
			},
			"core/code": {
				"typography": {
					"fontSize": "var:preset|font-size|x-small",
					"fontWeight": "300",
					"lineHeight": "1.3"
				},
				"color": {
					"text": "var:preset|color|background",
					"background": "var:preset|color|font"
				},
				"spacing": {
					"padding": {
						"right": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40",
						"left": "var:preset|spacing|40",
						"top": "var:preset|spacing|40"
					}
				},
				"border": {
					"radius": "6px"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var:preset|font-family|primary",
					"fontSize": "var:preset|font-size|small",
					"fontStyle": "italic",
					"lineHeight": "1.6",
					"fontWeight": "300"
				},
				"color": {
					"text": "var:preset|color|font",
					"background": "var:preset|color|gray-light"
				},
				"border": {
					"color": "var:preset|color|main-2",
					"style": "solid",
					"width": "0 0 0 4px",
					"radius": "6px"
				},
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|50",
						"right": "0",
						"bottom": "var:preset|spacing|50",
						"left": "0"
					},
					"padding": {
						"bottom": "var:preset|spacing|50",
						"left": "var:preset|spacing|60",
						"right": "var:preset|spacing|60",
						"top": "var:preset|spacing|50"
					}
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var:preset|color|main-2"
				}
			},
			"core/html": {
				"typography": {
					"fontFamily": "var:preset|font-family|primary",
					"fontSize": "var:preset|font-size|small",
					"lineHeight": "1.3"
				}
			},
			"core/categories": {
				"color": {
					"text": "var:preset|color|tertiary"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						},
						"typography": {
							"fontWeight": "500"
						}
					}
				}
			},
			"core/post-title": {
				"color": {
					"text": "var:preset|color|font"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|primary"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "var:preset|spacing|50"
					}
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var:preset|color|font"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/post-terms": {
				"color": {
					"text": "var:preset|color|tertiary"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/post-author": {
				"color": {
					"text": "var:preset|color|font"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				},
				"css": "&.wp-block-post-author__avatar img{border-radius:50%;}"
			},
			"core/post-excerpt": {
				"color": {
					"text": "var:preset|color|font-2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "6px"
				}
			},
			"core/post-template": {
				"css": ".wp-block-post-template-is-layout-grid .wp-block-columns-is-layout-flex{flex-direction: column;} &.wp-block-post-template-is-layout-grid .wp-block-post-excerpt{margin-top: 0;}"
			},
			"core/query-pagination-next": {
				"color": {
					"text": "var:preset|color|font"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/query-pagination": {
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font"
						},
						"spacing": {
							"padding": {
								"bottom": "var:preset|spacing|10",
								"left": "15px",
								"right": "15px",
								"top": "var:preset|spacing|10"
							},
							"margin": {
								"bottom": "2px",
								"left": "2px",
								"right": "2px",
								"top": "2px"
							}
						},
						"border": {
							"color": "#f5f5f5",
							"style": "solid",
							"width": "1px",
							"radius": "6px"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|font",
								"background": "var:preset|color|main-2"
							},
							"typography": {
								"textDecoration": "none"
							},
							"border": {
								"color": "var:preset|color|main-2",
								"radius": "5px"
							}
						}
					}
				},
				"css": "& .page-numbers:is(.dots, .current){padding:var(--wp--preset--spacing--10) 15px; border:1px solid #f5f5f5; border-radius:5px;} & .current{background:var(--wp--preset--color--background); color: var(--wp--preset--color--main-2);} "
			},
			"core/query-no-results": {
				"color": {
					"background": "#f5f5f5"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|40",
						"right": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40",
						"left": "var:preset|spacing|40"
					},
					"margin": {
						"top": "var:preset|spacing|80"
					}
				},
				"border": {
					"color": "#aaaaaa",
					"radius": "5px",
					"style": "solid",
					"width": "1px"
				}
			},
			"core/comment-template": {
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|40",
						"bottom": "var:preset|spacing|40"
					},
					"margin": {
						"bottom": "var:preset|spacing|30"
					}
				}
			},
			"core/comment-author-name": {
				"color": {
					"text": "var:preset|color|font-2"
				},
				"typography": {
					"fontSize": "var:preset|font-size|x-small",
					"fontWeight": "600"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "13px"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|tertiary"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|main-2"
							}
						}
					}
				}
			},
			"core/comment-edit-link": {
				"typography": {
					"fontSize": "13px"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|main-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|font-2"
							}
						}
					}
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontSize": "13px"
				},
				"spacing": {
					"margin": {
						"top": "15px"
					}
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|main-2"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|font-2"
							}
						}
					}
				}
			},
			"core/comment-content": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				},
				"css": "&.dep"
			},
			"core/post-comments-form": {
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|40;"
					}
				},
				"css": "& .comment-form-comment textarea{margin-top:15px;} "
			},
			"core/comments-pagination": {
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|font-2"
						},
						"spacing": {
							"padding": {
								"bottom": "var:preset|spacing|10",
								"left": "15px",
								"right": "15px",
								"top": "var:preset|spacing|10"
							},
							"margin": {
								"bottom": "2px",
								"left": "2px",
								"right": "2px",
								"top": "2px"
							}
						},
						"border": {
							"color": "#f5f5f5",
							"style": "solid",
							"width": "1px",
							"radius": "5px"
						},
						":hover": {
							"color": {
